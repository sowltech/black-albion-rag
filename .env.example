# Black Albion RAG — local environment template
#
# Copy to .env (gitignored) and tune per machine. None of these are required
# to run the default build — the API is local-first.

# Override the data directory (colon-separated paths are supported)
# BLACK_ALBION_DATA_DIR=data/raw

# Cap the number of evidence rows returned per query (default in models.py: 5)
# RAG_TOP_K=5

# Token budget guidance for downstream LLM consumers (informational only)
# MAX_EVIDENCE_TOKENS=3000

# Strict mode flags (informational only; the API enforces tier semantics regardless)
# REQUIRE_CITATIONS=1
# BLACK_ALBION_MODE=evidence_first

# Optional: enable the ChromaDB vector pass (requires `pip install chromadb`)
# ENABLE_VECTOR_INGEST=0
